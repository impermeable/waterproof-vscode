{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ESNext", "DOM"],
    "noEmit": true,
    "skipLibCheck": true,
    "outDir": "./out-jest",
    "sourceMap": true,
    "strict": true
  },
  "include": [
    "__tests__/**/*",
    "editor/src/**/*",
    "shared/**/*"
  ]
}
